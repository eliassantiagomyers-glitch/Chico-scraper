import feedparser, json, os, requests
from datetime import datetime

# --- CONFIG ---
FEEDS = [
    {
        "name": "Chico City Meetings - Agendas",
        "url": "https://chico-ca.granicus.com/ViewPublisherRSS.php?view_id=2&mode=agendas"
    },
    {
        "name": "Chico City Meetings - Minutes",
        "url": "https://chico-ca.granicus.com/ViewPublisherRSS.php?view_id=2&mode=minutes"
    },
]

TELEGRAM_TOKEN = os.environ['TELEGRAM_TOKEN']
TELEGRAM_CHAT  = os.environ['TELEGRAM_CHAT_ID']
SEEN_FILE      = 'seen.json'
FINDINGS_FILE  = 'findings.json'

# --- HELPERS ---
def load_seen():
    if os.path.exists(SEEN_FILE):
        return set(json.load(open(SEEN_FILE)))
    return set()

def save_seen(seen):
    json.dump(list(seen), open(SEEN_FILE, 'w'))

def load_findings():
    if os.path.exists(FINDINGS_FILE):
        return json.load(open(FINDINGS_FILE))
    return []

def send_telegram(msg):
    requests.post(
        f'https://api.telegram.org/bot{TELEGRAM_TOKEN}/sendMessage',
        json={'chat_id': TELEGRAM_CHAT, 'text': msg, 'parse_mode': 'HTML'}
    )

# --- MAIN ---
def run():
    seen = load_seen()
    findings = load_findings()
    new_count = 0

    for feed in FEEDS:
        parsed = feedparser.parse(feed['url'])
        for entry in parsed.entries:
            uid = entry.get('id') or entry.get('link')
            if uid in seen:
                continue

            seen.add(uid)
            new_count += 1

            title = entry.get('title', 'Untitled')
            link  = entry.get('link', '')
            date  = entry.get('published', '')

            # Telegram alert
            msg = f"📋 <b>{feed['name']}</b>\n{title}\n{date}\n{link}"
            send_telegram(msg)

            # Save to findings
            findings.insert(0, {
                'source': feed['name'],
                'title': title,
                'link': link,
                'date': date,
                'fetched': datetime.utcnow().isoformat()
            })

    # Keep last 200 findings
    findings = findings[:200]
    json.dump(findings, open(FINDINGS_FILE, 'w'), indent=2)
    save_seen(seen)
    print(f"Done. {new_count} new items found.")

if __name__ == '__main__':
    run()
